# -----------------------------------------------
# Database
# -----------------------------------------------
DATABASE_URL=postgresql+asyncpg://appuser:devpassword@db:5432/english_app
POSTGRES_USER=appuser
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=english_app

# -----------------------------------------------
# JWT
# Generate a real secret: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------
JWT_SECRET_KEY=dev-secret-change-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------
# OpenAI (your real developer key goes here)
# -----------------------------------------------
OPENAI_DEV_API_KEY=sk-your-real-key-here

# -----------------------------------------------
# Free session limits
# -----------------------------------------------
FREE_SESSIONS_ADULT=5
FREE_SESSIONS_STUDENT=10

# -----------------------------------------------
# App
# -----------------------------------------------
DEBUG=true